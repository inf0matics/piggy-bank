# Logto admin authentication
# Register a "Traditional Web App" in the Logto Console (https://logto.io) and
# fill in the values below. See README.md ("Admin / Logto setup") for the
# required redirect URIs.
#
# Leaving these unset keeps the app running with admin login disabled. Once you
# set NUXT_LOGTO_ENDPOINT to enable admin auth, you MUST also set a real
# NUXT_LOGTO_COOKIE_ENCRYPTION_KEY (otherwise an insecure built-in key is used).
NUXT_LOGTO_ENDPOINT=https://<your-tenant>.logto.app/
NUXT_LOGTO_APP_ID=
NUXT_LOGTO_APP_SECRET=
NUXT_LOGTO_COOKIE_ENCRYPTION_KEY=   # any random string, e.g. `openssl rand -base64 32`

# SQLite database file for the user store. Defaults to data/piggy-bank.db
# (relative to the working directory). In Docker, point it at a mounted volume
# so the data persists across restarts, e.g. DATABASE_PATH=/data/piggy-bank.db
# with a volume mounted at /data.
DATABASE_PATH=data/piggy-bank.db
